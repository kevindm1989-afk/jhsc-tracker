{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts"
  },
  "dependencies": {
  "drizzle-orm": "^0.45.2",
  "drizzle-zod": "^0.8.3",
  "pg": "^8.20.0",
  "zod": "3.25.76"
},
"devDependencies": {
  "@types/node": "^25.3.3",
  "@types/pg": "^8.18.0",
  "drizzle-kit": "^0.31.9"
}
}